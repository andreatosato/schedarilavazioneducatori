{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.44.1.10279",
      "templateHash": "925227558421076634"
    }
  },
  "parameters": {
    "name": {
      "type": "string",
      "defaultValue": "black-sand-00abc5803",
      "metadata": {
        "description": "Base name used to derive the resource names."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "westeurope",
      "allowedValues": [
        "westeurope",
        "northeurope",
        "eastus2",
        "centralus",
        "westus2",
        "eastasia"
      ],
      "metadata": {
        "description": "Location for the Static Web App. Only a subset of regions support Static Web Apps."
      }
    },
    "cosmosLocation": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Location for the Cosmos DB account. Defaults to the resource group location."
      }
    },
    "sku": {
      "type": "string",
      "defaultValue": "Free",
      "allowedValues": [
        "Free",
        "Standard"
      ],
      "metadata": {
        "description": "Pricing tier (SKU) for the Static Web App."
      }
    },
    "enableCosmosFreeTier": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Enable the Cosmos DB lifetime Free Tier (1000 RU/s throughput and 25 GB storage free). Only one free-tier account is allowed per subscription, so set this to false if the subscription already has one."
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {
        "project": "strade-aperte"
      },
      "metadata": {
        "description": "Tags applied to every resource."
      }
    }
  },
  "variables": {
    "cosmosAccountName": "[toLower(format('{0}-cosmos', parameters('name')))]",
    "cosmosDatabaseName": "schede",
    "cosmosContainerName": "schede"
  },
  "resources": [
    {
      "type": "Microsoft.DocumentDB/databaseAccounts",
      "apiVersion": "2024-11-15",
      "name": "[variables('cosmosAccountName')]",
      "location": "[parameters('cosmosLocation')]",
      "tags": "[parameters('tags')]",
      "kind": "GlobalDocumentDB",
      "properties": {
        "databaseAccountOfferType": "Standard",
        "enableFreeTier": "[parameters('enableCosmosFreeTier')]",
        "consistencyPolicy": {
          "defaultConsistencyLevel": "Session"
        },
        "locations": [
          {
            "locationName": "[parameters('cosmosLocation')]",
            "failoverPriority": 0,
            "isZoneRedundant": false
          }
        ]
      }
    },
    {
      "type": "Microsoft.DocumentDB/databaseAccounts/sqlDatabases",
      "apiVersion": "2024-11-15",
      "name": "[format('{0}/{1}', variables('cosmosAccountName'), variables('cosmosDatabaseName'))]",
      "properties": {
        "resource": {
          "id": "[variables('cosmosDatabaseName')]"
        },
        "options": {
          "autoscaleSettings": {
            "maxThroughput": 1000
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.DocumentDB/databaseAccounts', variables('cosmosAccountName'))]"
      ]
    },
    {
      "type": "Microsoft.DocumentDB/databaseAccounts/sqlDatabases/containers",
      "apiVersion": "2024-11-15",
      "name": "[format('{0}/{1}/{2}', variables('cosmosAccountName'), variables('cosmosDatabaseName'), variables('cosmosContainerName'))]",
      "properties": {
        "resource": {
          "id": "[variables('cosmosContainerName')]",
          "partitionKey": {
            "paths": [
              "/id"
            ],
            "kind": "Hash"
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.DocumentDB/databaseAccounts/sqlDatabases', variables('cosmosAccountName'), variables('cosmosDatabaseName'))]"
      ]
    },
    {
      "type": "Microsoft.Web/staticSites",
      "apiVersion": "2024-04-01",
      "name": "[parameters('name')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "sku": {
        "name": "[parameters('sku')]",
        "tier": "[parameters('sku')]"
      },
      "properties": {
        "allowConfigFileUpdates": true,
        "stagingEnvironmentPolicy": "Enabled"
      }
    },
    {
      "type": "Microsoft.Web/staticSites/databaseConnections",
      "apiVersion": "2024-04-01",
      "name": "[format('{0}/{1}', parameters('name'), 'default')]",
      "properties": {
        "resourceId": "[resourceId('Microsoft.DocumentDB/databaseAccounts', variables('cosmosAccountName'))]",
        "region": "[parameters('cosmosLocation')]",
        "connectionString": "[listConnectionStrings(resourceId('Microsoft.DocumentDB/databaseAccounts', variables('cosmosAccountName')), '2024-11-15').connectionStrings[0].connectionString]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.DocumentDB/databaseAccounts', variables('cosmosAccountName'))]",
        "[resourceId('Microsoft.Web/staticSites', parameters('name'))]"
      ]
    }
  ],
  "outputs": {
    "staticWebAppName": {
      "type": "string",
      "metadata": {
        "description": "The name of the provisioned Static Web App."
      },
      "value": "[parameters('name')]"
    },
    "defaultHostname": {
      "type": "string",
      "metadata": {
        "description": "The default public hostname of the Static Web App."
      },
      "value": "[reference(resourceId('Microsoft.Web/staticSites', parameters('name')), '2024-04-01').defaultHostname]"
    },
    "appUrl": {
      "type": "string",
      "metadata": {
        "description": "The full public URL of the app."
      },
      "value": "[format('https://{0}', reference(resourceId('Microsoft.Web/staticSites', parameters('name')), '2024-04-01').defaultHostname)]"
    },
    "cosmosAccountName": {
      "type": "string",
      "metadata": {
        "description": "The name of the provisioned Cosmos DB account."
      },
      "value": "[variables('cosmosAccountName')]"
    }
  }
}