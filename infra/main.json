{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.44.1.10279",
      "templateHash": "220801366931099681"
    }
  },
  "parameters": {
    "name": {
      "type": "string",
      "defaultValue": "black-sand-00abc5803",
      "metadata": {
        "description": "Base name used to derive the resource names."
      }
    },
    "cosmosLocation": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Location for the Cosmos DB account. Defaults to the resource group location."
      }
    },
    "enableCosmosFreeTier": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Enable the Cosmos DB lifetime Free Tier (1000 RU/s throughput and 25 GB storage free). Only one free-tier account is allowed per subscription, so set this to false if the subscription already has one."
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {
        "project": "strade-aperte"
      },
      "metadata": {
        "description": "Tags applied to every resource."
      }
    }
  },
  "variables": {
    "cosmosAccountName": "[toLower(format('{0}-cosmos', parameters('name')))]",
    "cosmosDatabaseName": "schede",
    "cosmosContainerName": "schede"
  },
  "resources": [
    {
      "type": "Microsoft.DocumentDB/databaseAccounts",
      "apiVersion": "2024-11-15",
      "name": "[variables('cosmosAccountName')]",
      "location": "[parameters('cosmosLocation')]",
      "tags": "[parameters('tags')]",
      "kind": "GlobalDocumentDB",
      "properties": {
        "databaseAccountOfferType": "Standard",
        "enableFreeTier": "[parameters('enableCosmosFreeTier')]",
        "consistencyPolicy": {
          "defaultConsistencyLevel": "Session"
        },
        "locations": [
          {
            "locationName": "[parameters('cosmosLocation')]",
            "failoverPriority": 0,
            "isZoneRedundant": false
          }
        ]
      }
    },
    {
      "type": "Microsoft.DocumentDB/databaseAccounts/sqlDatabases",
      "apiVersion": "2024-11-15",
      "name": "[format('{0}/{1}', variables('cosmosAccountName'), variables('cosmosDatabaseName'))]",
      "properties": {
        "resource": {
          "id": "[variables('cosmosDatabaseName')]"
        },
        "options": {
          "autoscaleSettings": {
            "maxThroughput": 1000
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.DocumentDB/databaseAccounts', variables('cosmosAccountName'))]"
      ]
    },
    {
      "type": "Microsoft.DocumentDB/databaseAccounts/sqlDatabases/containers",
      "apiVersion": "2024-11-15",
      "name": "[format('{0}/{1}/{2}', variables('cosmosAccountName'), variables('cosmosDatabaseName'), variables('cosmosContainerName'))]",
      "properties": {
        "resource": {
          "id": "[variables('cosmosContainerName')]",
          "partitionKey": {
            "paths": [
              "/id"
            ],
            "kind": "Hash"
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.DocumentDB/databaseAccounts/sqlDatabases', variables('cosmosAccountName'), variables('cosmosDatabaseName'))]"
      ]
    }
  ],
  "outputs": {
    "cosmosAccountName": {
      "type": "string",
      "metadata": {
        "description": "The name of the provisioned Cosmos DB account."
      },
      "value": "[variables('cosmosAccountName')]"
    },
    "cosmosDatabaseName": {
      "type": "string",
      "metadata": {
        "description": "The name of the provisioned Cosmos DB SQL database."
      },
      "value": "[variables('cosmosDatabaseName')]"
    },
    "cosmosContainerName": {
      "type": "string",
      "metadata": {
        "description": "The name of the provisioned Cosmos DB SQL container."
      },
      "value": "[variables('cosmosContainerName')]"
    }
  }
}