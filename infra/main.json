{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.37.4.10188",
      "templateHash": "1054922003437975077"
    }
  },
  "parameters": {
    "name": {
      "type": "string",
      "defaultValue": "stradeaperte",
      "metadata": {
        "description": "Base name used to derive the resource names."
      }
    },
    "cosmosAccountName": {
      "type": "string",
      "defaultValue": "[parameters('name')]",
      "metadata": {
        "description": "Name of the Cosmos DB account. Defaults to the base name so the account can match the Static Web App resource name."
      }
    },
    "cosmosLocation": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Location for the Cosmos DB account. Defaults to the resource group location."
      }
    },
    "enableCosmosFreeTier": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Enable the Cosmos DB lifetime Free Tier (1000 RU/s throughput and 25 GB storage free). Only one free-tier account is allowed per subscription, so set this to false if the subscription already has one."
      }
    },
    "staticWebAppName": {
      "type": "string",
      "defaultValue": "[parameters('name')]",
      "metadata": {
        "description": "Name of the existing Static Web App whose application settings receive the Cosmos DB connection string. Defaults to the base name."
      }
    },
    "configureStaticWebAppSettings": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "When true, sets the Cosmos DB application setting on the Static Web App. This is only needed for legacy SWA-managed Functions; the dedicated Function App receives its own setting."
      }
    },
    "assignCosmosDataRole": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "When true, grants the Static Web App system-assigned managed identity the Cosmos DB Built-in Data Contributor role. This is only needed for legacy SWA-managed Functions."
      }
    },
    "deployFunctionApp": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "When true, provisions a standalone Linux Azure Function App (with its own storage account and consumption plan) to host the schede API. Unlike the Static Web Apps managed Functions, a dedicated Function App fully supports managed identity, so Cosmos DB Entra ID authentication works at runtime."
      }
    },
    "functionAppName": {
      "type": "string",
      "defaultValue": "[format('{0}-api', parameters('name'))]",
      "metadata": {
        "description": "Name of the standalone Function App that hosts the API. Defaults to \"<name>-api\"."
      }
    },
    "linkFunctionAppToStaticWebApp": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "When true, links the standalone Function App to the Static Web App as a \"bring your own\" backend so requests to /api/* are routed to it. Linked backends require the Static Web App Standard plan."
      }
    },
    "functionAppLocation": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Location for the Function App, storage account and plan. Defaults to the resource group location."
      }
    },
    "deployApplicationInsights": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "When true, provisions Application Insights and wires it to the dedicated Function App."
      }
    },
    "logAnalyticsWorkspaceName": {
      "type": "string",
      "defaultValue": "[format('{0}-logs', parameters('name'))]",
      "metadata": {
        "description": "Name of the Log Analytics workspace used by Application Insights."
      }
    },
    "applicationInsightsName": {
      "type": "string",
      "defaultValue": "[format('{0}-appi', parameters('name'))]",
      "metadata": {
        "description": "Name of the Application Insights component used by the Function App."
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {
        "project": "strade-aperte"
      },
      "metadata": {
        "description": "Tags applied to every resource."
      }
    }
  },
  "variables": {
    "cosmosDatabaseName": "schede",
    "cosmosContainerName": "schede",
    "cosmosDataContributorRoleId": "[format('{0}/sqlRoleDefinitions/00000000-0000-0000-0000-000000000002', resourceId('Microsoft.DocumentDB/databaseAccounts', toLower(parameters('cosmosAccountName'))))]"
  },
  "resources": [
    {
      "type": "Microsoft.DocumentDB/databaseAccounts",
      "apiVersion": "2024-11-15",
      "name": "[toLower(parameters('cosmosAccountName'))]",
      "location": "[parameters('cosmosLocation')]",
      "tags": "[parameters('tags')]",
      "kind": "GlobalDocumentDB",
      "properties": {
        "databaseAccountOfferType": "Standard",
        "enableFreeTier": "[parameters('enableCosmosFreeTier')]",
        "consistencyPolicy": {
          "defaultConsistencyLevel": "Session"
        },
        "locations": [
          {
            "locationName": "[parameters('cosmosLocation')]",
            "failoverPriority": 0,
            "isZoneRedundant": false
          }
        ]
      }
    },
    {
      "type": "Microsoft.DocumentDB/databaseAccounts/sqlDatabases",
      "apiVersion": "2024-11-15",
      "name": "[format('{0}/{1}', toLower(parameters('cosmosAccountName')), variables('cosmosDatabaseName'))]",
      "properties": {
        "resource": {
          "id": "[variables('cosmosDatabaseName')]"
        },
        "options": {
          "autoscaleSettings": {
            "maxThroughput": 1000
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.DocumentDB/databaseAccounts', toLower(parameters('cosmosAccountName')))]"
      ]
    },
    {
      "type": "Microsoft.DocumentDB/databaseAccounts/sqlDatabases/containers",
      "apiVersion": "2024-11-15",
      "name": "[format('{0}/{1}/{2}', toLower(parameters('cosmosAccountName')), variables('cosmosDatabaseName'), variables('cosmosContainerName'))]",
      "properties": {
        "resource": {
          "id": "[variables('cosmosContainerName')]",
          "partitionKey": {
            "paths": [
              "/id"
            ],
            "kind": "Hash"
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.DocumentDB/databaseAccounts/sqlDatabases', toLower(parameters('cosmosAccountName')), variables('cosmosDatabaseName'))]"
      ]
    },
    {
      "condition": "[parameters('configureStaticWebAppSettings')]",
      "type": "Microsoft.Web/staticSites/config",
      "apiVersion": "2024-04-01",
      "name": "[format('{0}/{1}', parameters('staticWebAppName'), 'appsettings')]",
      "properties": {
        "COSMOS_ENDPOINT": "[reference(resourceId('Microsoft.DocumentDB/databaseAccounts', toLower(parameters('cosmosAccountName'))), '2024-11-15').documentEndpoint]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.DocumentDB/databaseAccounts', toLower(parameters('cosmosAccountName')))]"
      ]
    },
    {
      "condition": "[and(parameters('deployFunctionApp'), parameters('deployApplicationInsights'))]",
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2023-09-01",
      "name": "[parameters('logAnalyticsWorkspaceName')]",
      "location": "[parameters('functionAppLocation')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 30
      }
    },
    {
      "condition": "[and(parameters('deployFunctionApp'), parameters('deployApplicationInsights'))]",
      "type": "Microsoft.Insights/components",
      "apiVersion": "2020-02-02",
      "name": "[parameters('applicationInsightsName')]",
      "location": "[parameters('functionAppLocation')]",
      "tags": "[parameters('tags')]",
      "kind": "web",
      "properties": {
        "Application_Type": "web",
        "WorkspaceResourceId": "[resourceId('Microsoft.OperationalInsights/workspaces', parameters('logAnalyticsWorkspaceName'))]",
        "IngestionMode": "LogAnalytics"
      },
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', parameters('logAnalyticsWorkspaceName'))]"
      ]
    },
    {
      "condition": "[parameters('assignCosmosDataRole')]",
      "type": "Microsoft.DocumentDB/databaseAccounts/sqlRoleAssignments",
      "apiVersion": "2024-11-15",
      "name": "[format('{0}/{1}', toLower(parameters('cosmosAccountName')), guid(resourceId('Microsoft.DocumentDB/databaseAccounts', toLower(parameters('cosmosAccountName'))), parameters('staticWebAppName'), '00000000-0000-0000-0000-000000000002'))]",
      "properties": {
        "roleDefinitionId": "[variables('cosmosDataContributorRoleId')]",
        "principalId": "[reference(resourceId('Microsoft.Web/staticSites', parameters('staticWebAppName')), '2024-04-01', 'full').identity.principalId]",
        "scope": "[resourceId('Microsoft.DocumentDB/databaseAccounts', toLower(parameters('cosmosAccountName')))]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.DocumentDB/databaseAccounts', toLower(parameters('cosmosAccountName')))]"
      ]
    },
    {
      "condition": "[parameters('deployFunctionApp')]",
      "type": "Microsoft.DocumentDB/databaseAccounts/sqlRoleAssignments",
      "apiVersion": "2024-11-15",
      "name": "[format('{0}/{1}', toLower(parameters('cosmosAccountName')), guid(resourceId('Microsoft.DocumentDB/databaseAccounts', toLower(parameters('cosmosAccountName'))), parameters('functionAppName'), '00000000-0000-0000-0000-000000000002'))]",
      "properties": {
        "roleDefinitionId": "[variables('cosmosDataContributorRoleId')]",
        "principalId": "[reference(resourceId('Microsoft.Resources/deployments', 'functionAppDeployment'), '2022-09-01').outputs.principalId.value]",
        "scope": "[resourceId('Microsoft.DocumentDB/databaseAccounts', toLower(parameters('cosmosAccountName')))]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.DocumentDB/databaseAccounts', toLower(parameters('cosmosAccountName')))]",
        "[resourceId('Microsoft.Resources/deployments', 'functionAppDeployment')]"
      ]
    },
    {
      "condition": "[and(parameters('deployFunctionApp'), parameters('linkFunctionAppToStaticWebApp'))]",
      "type": "Microsoft.Web/staticSites/linkedBackends",
      "apiVersion": "2024-04-01",
      "name": "[format('{0}/{1}', parameters('staticWebAppName'), 'schede-api')]",
      "properties": {
        "backendResourceId": "[reference(resourceId('Microsoft.Resources/deployments', 'functionAppDeployment'), '2022-09-01').outputs.functionAppId.value]",
        "region": "[parameters('functionAppLocation')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Resources/deployments', 'functionAppDeployment')]"
      ]
    },
    {
      "condition": "[and(parameters('deployFunctionApp'), parameters('linkFunctionAppToStaticWebApp'))]",
      "type": "Microsoft.Web/sites/config",
      "apiVersion": "2024-04-01",
      "name": "[format('{0}/{1}', parameters('functionAppName'), 'authsettingsV2')]",
      "properties": {
        "platform": {
          "enabled": false
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/staticSites/linkedBackends', parameters('staticWebAppName'), 'schede-api')]"
      ]
    },
    {
      "condition": "[parameters('deployFunctionApp')]",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2022-09-01",
      "name": "functionAppDeployment",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "functionAppName": {
            "value": "[parameters('functionAppName')]"
          },
          "location": {
            "value": "[parameters('functionAppLocation')]"
          },
          "cosmosEndpoint": {
            "value": "[reference(resourceId('Microsoft.DocumentDB/databaseAccounts', toLower(parameters('cosmosAccountName'))), '2024-11-15').documentEndpoint]"
          },
          "applicationInsightsConnectionString": "[if(and(parameters('deployFunctionApp'), parameters('deployApplicationInsights')), createObject('value', reference(resourceId('Microsoft.Insights/components', parameters('applicationInsightsName')), '2020-02-02').ConnectionString), createObject('value', ''))]",
          "tags": {
            "value": "[parameters('tags')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.37.4.10188",
              "templateHash": "10007997506955804457"
            }
          },
          "parameters": {
            "functionAppName": {
              "type": "string",
              "metadata": {
                "description": "Name of the Function App that hosts the API."
              }
            },
            "location": {
              "type": "string",
              "metadata": {
                "description": "Location for the Function App, storage account and plan."
              }
            },
            "cosmosEndpoint": {
              "type": "string",
              "metadata": {
                "description": "Cosmos DB account endpoint to expose as the COSMOS_ENDPOINT app setting."
              }
            },
            "applicationInsightsConnectionString": {
              "type": "string",
              "defaultValue": "",
              "metadata": {
                "description": "Application Insights connection string. Leave empty to disable Function App telemetry wiring."
              }
            },
            "tags": {
              "type": "object",
              "defaultValue": {},
              "metadata": {
                "description": "Tags applied to every resource."
              }
            }
          },
          "variables": {
            "storageAccountName": "[toLower(format('fn{0}', uniqueString(resourceGroup().id, parameters('functionAppName'), parameters('location'))))]",
            "telemetryAppSettings": "[if(empty(parameters('applicationInsightsConnectionString')), createArray(), createArray(createObject('name', 'APPLICATIONINSIGHTS_CONNECTION_STRING', 'value', parameters('applicationInsightsConnectionString'))))]",
            "storageBlobDataOwnerRoleId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', 'b7e6dc6d-f1e8-4753-8033-0f276bb0955b')]",
            "storageQueueDataContributorRoleId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '974c5e8b-45b9-4653-ba55-5f855dd0fb88')]",
            "storageTableDataContributorRoleId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '0a9a7e1f-b9d0-4cc4-a60d-0319b160aaa3')]",
            "storageAccountContributorRoleId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '17d1049b-9a84-46fb-8f53-869881c3d3ab')]"
          },
          "resources": [
            {
              "type": "Microsoft.Storage/storageAccounts",
              "apiVersion": "2023-05-01",
              "name": "[variables('storageAccountName')]",
              "location": "[parameters('location')]",
              "tags": "[parameters('tags')]",
              "sku": {
                "name": "Standard_LRS"
              },
              "kind": "StorageV2",
              "properties": {
                "minimumTlsVersion": "TLS1_2",
                "allowSharedKeyAccess": false,
                "allowBlobPublicAccess": false,
                "publicNetworkAccess": "Enabled",
                "networkAcls": {
                  "bypass": "AzureServices",
                  "defaultAction": "Allow"
                },
                "supportsHttpsTrafficOnly": true
              }
            },
            {
              "type": "Microsoft.Web/serverfarms",
              "apiVersion": "2023-12-01",
              "name": "[format('{0}-plan', parameters('functionAppName'))]",
              "location": "[parameters('location')]",
              "tags": "[parameters('tags')]",
              "kind": "linux",
              "sku": {
                "name": "Y1",
                "tier": "Dynamic"
              },
              "properties": {
                "reserved": true
              }
            },
            {
              "type": "Microsoft.Web/sites",
              "apiVersion": "2023-12-01",
              "name": "[parameters('functionAppName')]",
              "location": "[parameters('location')]",
              "tags": "[parameters('tags')]",
              "kind": "functionapp,linux",
              "identity": {
                "type": "SystemAssigned"
              },
              "properties": {
                "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', format('{0}-plan', parameters('functionAppName')))]",
                "reserved": true,
                "httpsOnly": true,
                "siteConfig": {
                  "linuxFxVersion": "Node|22",
                  "ftpsState": "Disabled",
                  "minTlsVersion": "1.2",
                  "appSettings": "[concat(createArray(createObject('name', 'AzureWebJobsStorage__blobServiceUri', 'value', reference(resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName')), '2023-05-01').primaryEndpoints.blob), createObject('name', 'AzureWebJobsStorage__queueServiceUri', 'value', reference(resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName')), '2023-05-01').primaryEndpoints.queue), createObject('name', 'AzureWebJobsStorage__tableServiceUri', 'value', reference(resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName')), '2023-05-01').primaryEndpoints.table), createObject('name', 'AzureWebJobsStorage__credential', 'value', 'managedidentity'), createObject('name', 'FUNCTIONS_EXTENSION_VERSION', 'value', '~4'), createObject('name', 'FUNCTIONS_WORKER_RUNTIME', 'value', 'node'), createObject('name', 'WEBSITE_NODE_DEFAULT_VERSION', 'value', '~22'), createObject('name', 'COSMOS_ENDPOINT', 'value', parameters('cosmosEndpoint'))), variables('telemetryAppSettings'))]"
                }
              },
              "dependsOn": [
                "[resourceId('Microsoft.Web/serverfarms', format('{0}-plan', parameters('functionAppName')))]",
                "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]"
              ]
            },
            {
              "type": "Microsoft.Authorization/roleAssignments",
              "apiVersion": "2022-04-01",
              "scope": "[format('Microsoft.Storage/storageAccounts/{0}', variables('storageAccountName'))]",
              "name": "[guid(resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName')), resourceId('Microsoft.Web/sites', parameters('functionAppName')), variables('storageBlobDataOwnerRoleId'))]",
              "properties": {
                "roleDefinitionId": "[variables('storageBlobDataOwnerRoleId')]",
                "principalId": "[reference(resourceId('Microsoft.Web/sites', parameters('functionAppName')), '2023-12-01', 'full').identity.principalId]",
                "principalType": "ServicePrincipal"
              },
              "dependsOn": [
                "[resourceId('Microsoft.Web/sites', parameters('functionAppName'))]",
                "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]"
              ]
            },
            {
              "type": "Microsoft.Authorization/roleAssignments",
              "apiVersion": "2022-04-01",
              "scope": "[format('Microsoft.Storage/storageAccounts/{0}', variables('storageAccountName'))]",
              "name": "[guid(resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName')), resourceId('Microsoft.Web/sites', parameters('functionAppName')), variables('storageQueueDataContributorRoleId'))]",
              "properties": {
                "roleDefinitionId": "[variables('storageQueueDataContributorRoleId')]",
                "principalId": "[reference(resourceId('Microsoft.Web/sites', parameters('functionAppName')), '2023-12-01', 'full').identity.principalId]",
                "principalType": "ServicePrincipal"
              },
              "dependsOn": [
                "[resourceId('Microsoft.Web/sites', parameters('functionAppName'))]",
                "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]"
              ]
            },
            {
              "type": "Microsoft.Authorization/roleAssignments",
              "apiVersion": "2022-04-01",
              "scope": "[format('Microsoft.Storage/storageAccounts/{0}', variables('storageAccountName'))]",
              "name": "[guid(resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName')), resourceId('Microsoft.Web/sites', parameters('functionAppName')), variables('storageTableDataContributorRoleId'))]",
              "properties": {
                "roleDefinitionId": "[variables('storageTableDataContributorRoleId')]",
                "principalId": "[reference(resourceId('Microsoft.Web/sites', parameters('functionAppName')), '2023-12-01', 'full').identity.principalId]",
                "principalType": "ServicePrincipal"
              },
              "dependsOn": [
                "[resourceId('Microsoft.Web/sites', parameters('functionAppName'))]",
                "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]"
              ]
            },
            {
              "type": "Microsoft.Authorization/roleAssignments",
              "apiVersion": "2022-04-01",
              "scope": "[format('Microsoft.Storage/storageAccounts/{0}', variables('storageAccountName'))]",
              "name": "[guid(resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName')), resourceId('Microsoft.Web/sites', parameters('functionAppName')), variables('storageAccountContributorRoleId'))]",
              "properties": {
                "roleDefinitionId": "[variables('storageAccountContributorRoleId')]",
                "principalId": "[reference(resourceId('Microsoft.Web/sites', parameters('functionAppName')), '2023-12-01', 'full').identity.principalId]",
                "principalType": "ServicePrincipal"
              },
              "dependsOn": [
                "[resourceId('Microsoft.Web/sites', parameters('functionAppName'))]",
                "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]"
              ]
            }
          ],
          "outputs": {
            "functionAppId": {
              "type": "string",
              "metadata": {
                "description": "The resource ID of the Function App (used to link it as a SWA backend)."
              },
              "value": "[resourceId('Microsoft.Web/sites', parameters('functionAppName'))]"
            },
            "functionAppName": {
              "type": "string",
              "metadata": {
                "description": "The name of the Function App."
              },
              "value": "[parameters('functionAppName')]"
            },
            "principalId": {
              "type": "string",
              "metadata": {
                "description": "The principal ID of the Function App system-assigned managed identity."
              },
              "value": "[reference(resourceId('Microsoft.Web/sites', parameters('functionAppName')), '2023-12-01', 'full').identity.principalId]"
            }
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Insights/components', parameters('applicationInsightsName'))]",
        "[resourceId('Microsoft.DocumentDB/databaseAccounts', toLower(parameters('cosmosAccountName')))]"
      ]
    }
  ],
  "outputs": {
    "cosmosAccountName": {
      "type": "string",
      "metadata": {
        "description": "The name of the provisioned Cosmos DB account."
      },
      "value": "[toLower(parameters('cosmosAccountName'))]"
    },
    "cosmosDatabaseName": {
      "type": "string",
      "metadata": {
        "description": "The name of the provisioned Cosmos DB SQL database."
      },
      "value": "[variables('cosmosDatabaseName')]"
    },
    "cosmosContainerName": {
      "type": "string",
      "metadata": {
        "description": "The name of the provisioned Cosmos DB SQL container."
      },
      "value": "[variables('cosmosContainerName')]"
    },
    "cosmosEndpoint": {
      "type": "string",
      "metadata": {
        "description": "The Cosmos DB account endpoint to set as the COSMOS_ENDPOINT application setting."
      },
      "value": "[reference(resourceId('Microsoft.DocumentDB/databaseAccounts', toLower(parameters('cosmosAccountName'))), '2024-11-15').documentEndpoint]"
    },
    "functionAppName": {
      "type": "string",
      "metadata": {
        "description": "The name of the standalone Function App that hosts the API (empty when not deployed)."
      },
      "value": "[if(parameters('deployFunctionApp'), reference(resourceId('Microsoft.Resources/deployments', 'functionAppDeployment'), '2022-09-01').outputs.functionAppName.value, '')]"
    },
    "applicationInsightsName": {
      "type": "string",
      "metadata": {
        "description": "The name of the Application Insights component (empty when not deployed)."
      },
      "value": "[if(and(parameters('deployFunctionApp'), parameters('deployApplicationInsights')), parameters('applicationInsightsName'), '')]"
    }
  }
}